# DevAgent — Environment Variables Reference
# Copy this file to .env for local development
# NEVER commit .env to git (it's in .gitignore)

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
PORT=8000
ALLOWED_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
DOCS_ENABLED=true

# ── Database ──────────────────────────────────────────────────────────────────
# Default: <project_root>/devagent.db (no need to set in dev)
# DATABASE_PATH=/data/devagent.db    # Uncomment for Render production

# ── Authentication (Phase 1) ──────────────────────────────────────────────────
# Generate JWT secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_secrets_token_hex_32_IN_PRODUCTION
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=false       # true in production (HTTPS)
APP_BASE_URL=http://localhost:8000
APP_NAME=DevAgent

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Set EMAIL_VERIFICATION_ENABLED=false in dev to skip email verification
EMAIL_VERIFICATION_ENABLED=false

# Configure SMTP for real email sending (optional in dev, required in prod):
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=DevAgent <noreply@devagent.io>

# ── Rate limits (optional overrides) ──────────────────────────────────────────
# RATE_LIMIT_LOGIN=10/minute
# RATE_LIMIT_SIGNUP=5/minute
# RATE_LIMIT_FORGOT=3/minute

# ── Jira (optional) ──────────────────────────────────────────────────────────
# JIRA_BASE_URL=https://yourcompany.atlassian.net
# JIRA_EMAIL=your-email@company.com
# JIRA_API_TOKEN=your-jira-api-token
